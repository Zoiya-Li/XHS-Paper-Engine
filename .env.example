# XHS Paper Engine Environment Variables Configuration
#
# Set the key for whichever provider you select via `api.provider` in config.yaml.
# You only need ONE provider's key. All are OpenAI-compatible.

# Default provider: SiliconFlow 硅基流动 (CN)
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key

# ---- Other Chinese providers (set api.provider accordingly; all have VL) ----
# 阿里云百炼 / 通义千问   (api.provider=dashscope)
DASHSCOPE_API_KEY=
# 月之暗面 Kimi          (api.provider=moonshot)
MOONSHOT_API_KEY=
# 智谱 GLM               (api.provider=zhipu)
ZHIPU_API_KEY=

# ---- International / custom ----
# OpenRouter             (api.provider=openrouter)
OPENROUTER_API_KEY=
# Optional metadata for OpenRouter ranking/analytics
OPENROUTER_SITE_URL=https://your.site
OPENROUTER_APP_NAME=XHSPaperEngine
# Any other OpenAI-compatible endpoint (api.provider=custom; set api.custom.base_url in config.yaml)
CUSTOM_API_KEY=

# ============= Optional (for Enhanced Search) =============

# Semantic Scholar API Key (increases search quota)
# Get it from: https://www.semanticscholar.org/product/api
S2_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
